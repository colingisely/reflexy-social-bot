# Reflexy Social Bot — Variaveis de ambiente
# Copia para .env e preenche. NUNCA commitar .env.
# Em producao (GitHub Actions) estes valores ficam em repository secrets.

# ─── Instagram Graph API ───
IG_USER_ID=17841444019122638
IG_ACCESS_TOKEN=EAA...                         # long-lived 60d, renovado automaticamente

# ─── Meta App (para refresh do token) ───
META_APP_ID=2168242710629940
META_APP_SECRET=                               # 32 chars hex

# ─── Notion ───
NOTION_TOKEN=secret_...                        # gerar em notion.so/my-integrations + share DB
NOTION_DB_POSTS=2b933ab1275c4d4387b373bb873df9b8  # database "Posts Instagram"

# ─── Anthropic (refino de captions) ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── Notificacao (opcional) ───
ALERT_EMAIL=gcdigitaldesigner@gmail.com
